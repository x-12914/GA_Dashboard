# Copy this file to ".env" and fill in your values.

# --- Mode -------------------------------------------------------------
# Leave true to use built-in sample data. Set to false once GA4 is connected.
USE_MOCK=true

# --- Google Analytics 4 ----------------------------------------------
# Your numeric GA4 property id (Admin > Property Settings). NOT the "G-XXXX".
GA4_PROPERTY_ID=
# Path to the service-account JSON key you download from Google Cloud.
GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\service-account.json

# --- AI analyzer (optional) ------------------------------------------
# Which engine to use: auto | openai | claude | none
#   auto   = OpenAI if its key is set, else Claude, else rule-based
#   none   = always use the built-in rule-based analyzer
LLM_PROVIDER=auto

# OpenAI (using this for now)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Prospect Finder discovery (optional) ----------------------------
# Lets you type a niche and auto-discover stores. Without it, you can still
# paste a list of store URLs and the finder audits + ranks them.
# 1) Create a search engine (set to search the whole web): https://programmablesearchengine.google.com
#    -> copy the "Search engine ID" into GOOGLE_CSE_ID
# 2) Enable "Custom Search API" in Google Cloud; reuse your PageSpeed key or make a new one.
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ID=

# Claude (switch later: set the key, or LLM_PROVIDER=claude)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
