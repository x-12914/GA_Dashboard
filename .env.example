# Copy this file to ".env" and fill in your values.

# --- Mode -------------------------------------------------------------
# Leave true to use built-in sample data. Set to false once GA4 is connected.
USE_MOCK=true

# --- Google Analytics 4 ----------------------------------------------
# Your numeric GA4 property id (Admin > Property Settings). NOT the "G-XXXX".
GA4_PROPERTY_ID=
# Path to the service-account JSON key you download from Google Cloud.
GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\service-account.json

# --- AI analyzer (optional) ------------------------------------------
# Which engine to use: auto | openai | claude | none
#   auto   = OpenAI if its key is set, else Claude, else rule-based
#   none   = always use the built-in rule-based analyzer
LLM_PROVIDER=auto

# OpenAI (using this for now)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Prospect Finder discovery (optional) ----------------------------
# Lets you type a niche and auto-discover stores. Without it, you can still
# paste a list of store URLs and the finder audits + ranks them.
# Provider: auto | serper | jina | google  (auto = whichever key is set below)
SEARCH_PROVIDER=auto

# Serper.dev — recommended: just one key, generous free tier. https://serper.dev
SERPER_API_KEY=

# Jina AI search — alternative, just one key. https://jina.ai
JINA_API_KEY=

# Google Programmable Search — needs BOTH a key and a search-engine id (cx):
# 1) https://programmablesearchengine.google.com (set to search the whole web) -> GOOGLE_CSE_ID
# 2) Enable "Custom Search API" in Google Cloud (can reuse the PageSpeed key) -> GOOGLE_CSE_API_KEY
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ID=

# Claude (switch later: set the key, or LLM_PROVIDER=claude)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
